# ClawBio environment variables
# Copy to .env and fill in your keys

# FLock API — open-source model inference for intelligent routing
# Sign up at https://platform.flock.io
# Required for: Bio Orchestrator LLM routing (--provider flock)
# Not required for: all other skills (they are pure Python, no LLM needed)
FLOCK_API_KEY=your-flock-api-key-here

# Genomic Intelligence API — DNA-LM inference shared by the gi-* skills
# (gi-promoter, gi-splice, gi-enhancer, gi-chromatin, gi-annotation,
# gi-expression). The value below is a hackathon-tier shared key (concurrent=50,
# rpm=120). Heavy/serious use should request an individual key from
# alex@genomicintelligence.ai and replace this value.
GI_API_KEY=gi_cCtc4FLFXnh3f3NwTPUMcKIqLH7Y679L

# Optional override for the GI API base URL (defaults to
# https://api.genomicintelligence.ai)
# GI_BASE_URL=https://api.genomicintelligence.ai
